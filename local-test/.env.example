# Copia a local-test/.env y rellena. NO se sube (está en .gitignore: *.env).

# De dónde leer los manuales (la misma URL /exec y un usuario Admin)
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
ADMIN_USER=TU_USUARIO_ADMIN
ADMIN_PASS=TU_CONTRASEÑA

# Ollama local (en el propio servidor suele ser localhost)
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
# Prueba distintos: qwen2.5:7b, llama3.1, gemma3:12b, mistral-nemo:latest
CHAT_MODEL=qwen2.5:7b
