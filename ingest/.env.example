# Copia este archivo a ingest/.env y rellena los valores.
# NO subas ingest/.env al repositorio (está en .gitignore).

# Apps Script (la misma URL /exec del backend actual)
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# Un usuario con rol Admin (para que Apps Script autorice la lectura de contenido)
ADMIN_USER=TU_USUARIO_ADMIN
ADMIN_PASS=TU_CONTRASEÑA

# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Clave service_role (SECRETA). Solo se usa aquí, en tu máquina.
SUPABASE_SERVICE_ROLE=eyJhbGciOi...

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
# Modelo de embeddings (debe coincidir con la dimensión 1536 de la tabla)
EMBEDDING_MODEL=text-embedding-3-small
